# ============================================================
# Conversion Relay Server — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Server
PORT=3000
SESSION_SECRET=replace-with-a-long-random-string

# Dashboard login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-use-a-strong-password

# Database path (defaults to ./db/relay.db)
DB_PATH=./db/relay.db

# Global Google Ads Developer Token
# (If not set per-client, this global value is used)
GOOGLE_ADS_DEVELOPER_TOKEN=

# Optional: Meta test event code for all events (use Events Manager > Test Events)
# META_TEST_EVENT_CODE=TEST12345
